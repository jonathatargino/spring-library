# Copie para .env e ajuste os valores antes de subir em um ambiente real.
# Em desenvolvimento, docker-compose.yml já usa valores padrão se este arquivo não existir.

# Segredo compartilhado para assinar/validar os JWTs (front-ms assina, autor-ms e livro-ms validam).
# Use o mesmo valor nos três serviços. Mínimo de 32 caracteres (HS256).
JWT_SECRET=troque-este-segredo-compartilhado-em-producao-0123456789

# Usuários pré-cadastrados do front-ms (login).
BIBLIOTECARIO_USER=bibliotecario
BIBLIOTECARIO_PASS=biblioteca123
USUARIO_USER=usuario
USUARIO_PASS=usuario123
